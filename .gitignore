solid-work
docs/ArkMask

# Python bytecode cache (backend/ and workers/ both run pytest/uvicorn
# locally, which regenerates these on every run — never meant to be tracked)
__pycache__/
*.pyc
*.pyo

# FVM Version Cache
.fvm/

backend/arkmask-firebase.json

# ── Infra ─────────────────────────────────────────────────────────────────────

# Terraform local state and backup (remote state lives in GCS)
infra/terraform/**/*.tfstate
infra/terraform/**/*.tfstate.backup

# Terraform working directory — providers, module cache, plan files
# CI runs its own `terraform init` so these are never needed remotely
infra/terraform/**/.terraform/
infra/terraform/**/.terraform.lock.hcl
infra/terraform/**/tfplan

# Local variable overrides (never commit secrets or personal tfvars)
infra/terraform/**/*.auto.tfvars
infra/terraform/**/terraform.tfvars

# Firebase local credentials (service account JSON) — firebase.json (CLI
# config) and firestore.indexes.json are checked-in project config, not
# secrets, so they're explicitly un-ignored below.
infra/firebase/*.json
!infra/firebase/firebase.json
!infra/firebase/firestore.indexes.json

# SETUP scratch files that may contain real secret values
infra/*.json
infra/*.env

# Local scratch copies of the {env}-arkmask-config Secret Manager JSON
# payload (see infra/SETUP.md Step 6) — these contain the live Stripe
# secret key, webhook secret, and Firebase service account private key in
# plaintext and must never be committed, wherever they happen to be created.
config.json
*.config.json

# Claude Code workspace metadata
.claude/

# Flutter/Android build output
mobile/android/build/