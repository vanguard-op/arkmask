# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://arkmask:arkmask@localhost:5432/arkmask

# ── Object storage ────────────────────────────────────────────────────────────
# Local dev: MinIO (S3-compatible). Production: set to GCS bucket name.
STORAGE_BUCKET=arkmask-local
# Override endpoint for local MinIO. Leave empty for production GCS.
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
# Presigned URL TTL in seconds (2 hours = 7200)
STORAGE_PRESIGN_TTL=7200

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=arkmask-dev
# Path to Firebase Admin SDK service account JSON, OR leave empty to use
# Application Default Credentials (ADC) in Cloud Run.
FIREBASE_CREDENTIALS_PATH=

# ── Application ───────────────────────────────────────────────────────────────
# Environment: local | staging | production
APP_ENV=local
